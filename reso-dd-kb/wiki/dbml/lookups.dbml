// lookups.dbml
// 99 Enum blocks for RESO DD 2.0 single-value lookups.
// Companion to canonical.dbml.

Project reso_canonical_dd_2_0_lookups {
  database_type: 'PostgreSQL'
  Note: 'Single-value lookup enums extracted from raw/lookups.csv + raw/lookup_values.csv'
}

