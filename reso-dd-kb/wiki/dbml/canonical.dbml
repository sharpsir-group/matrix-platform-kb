  contact_type varchar [note: 'ContactType | The type of contact (i.e., Business, Friend, Family, Prospect, Ready to Buy, etc.). | type=String List, Multi | max_len=255 | multi: ContactType | lookup=ContactType']
  department varchar(50) [note: 'Department | The department in which the contact works. | type=String | max_len=50']
  direct_phone varchar(16) [note: 'DirectPhone | North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  email varchar(80) [note: 'Email | The preferred email address of the contact. | type=String | max_len=80']
  email2 varchar(80) [note: 'Email2 | The secondary email address of the contact. | type=String | max_len=80']
  email3 varchar(80) [note: 'Email3 | The tertiary email address of the contact. | type=String | max_len=80']
  first_name varchar(50) [note: 'FirstName | The first name of the contact. | type=String | max_len=50']
  full_name varchar(150) [note: 'FullName | The first, middle and last name of the contact or an alternate full name. | type=String | max_len=150']
