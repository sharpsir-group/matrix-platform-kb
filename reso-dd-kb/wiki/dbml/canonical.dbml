  team_key varchar(255) [note: 'TeamKey | A system unique identifier. | type=String | max_len=255']
  team_member_key varchar(255) [pk, note: 'TeamMemberKey | A system unique identifier. | type=String | max_len=255']
  team_member_national_association_id varchar(25) [note: 'TeamMemberNationalAssociationId | The national association ID of the member (e.g., in the U.S., this is an M1 or NRDS number). | type=String | max_len=25']
  team_member_state_license varchar(50) [note: 'TeamMemberStateLicense | The license of the member. | type=String | max_len=50']
  team_member_type team_member_type [note: 'TeamMemberType | The role of the member within the team (e.g., Team Lead, Showing Agent, Buyer Agent). | type=String List, Single | max_len=50 | lookup=TeamMemberType']
}

