  stop_showing_agent_first_name varchar(50) [note: 'StopShowingAgentFirstName | The first name of the showing agent for the caravan stop. | type=String | max_len=50']
  stop_showing_agent_key varchar(255) [note: 'StopShowingAgentKey | A system unique identifier for the caravan stop\'s showing agent. | type=String | max_len=255']
  // REVIEW: satellite of FK StopShowingAgentKey -> Member.MemberLastName; jaccard=0.500, type_match=1.0, signals=A|B|D, notes=borderline_jaccard
  stop_showing_agent_last_name varchar(50) [note: 'StopShowingAgentLastName | The last name of the showing agent for the caravan stop. | type=String | max_len=50']
  stop_start_time timestamp [note: 'StopStartTime | The time the caravan stop will be open. | type=Timestamp | max_len=27']
}

// ---- ContactListingNotes (10 fields on dd.reso.org) ----
// inverse 1:N: HistoryTransactional -> HistoryTransactional
Table contact_listing_notes {
  contact_key varchar(255) [note: 'ContactKey | The key of the corresponding contact record. | type=String | max_len=255']
  contact_listing_notes_key varchar(255) [pk, note: 'ContactListingNotesKey | A system unique identifier. | type=String | max_len=255']
  listing_id varchar(255) [note: 'ListingId | The ID for the corresponding listing record. | type=String | max_len=255']
  listing_key varchar(255) [note: 'ListingKey | The key of the corresponding listing record. | type=String | max_len=255']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time a note was written. | type=Timestamp | max_len=27']
  note_contents varchar(500) [note: 'NoteContents | The contents of a note. | type=String | max_len=500']
  noted_by noted_by [note: 'NotedBy | The individual who wrote a note (i.e., Agent or Contact). | type=String List, Single | max_len=25 | lookup=NotedBy']
}

