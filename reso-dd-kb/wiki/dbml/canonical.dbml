  birthdate date [note: 'Birthdate | The month, day and year of the contact\'s birthday. | type=Date | max_len=10']
  business_fax varchar(16) [note: 'BusinessFax | North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  children varchar(150) [note: 'Children | A list of the names of the contact\'s children in a comma-separated list. | type=String | max_len=150']
  company varchar(50) [note: 'Company | The contact\'s company or employer. | type=String | max_len=50']
  contact_key varchar(255) [pk, note: 'ContactKey | A system unique identifier. | type=String | max_len=255']
  contact_login_id varchar(25) [note: 'ContactLoginId | The local, well-known identifier for the contact. | type=String | max_len=25']
  contact_password varchar(25) [note: 'ContactPassword | A client password that the member wishes to share with other systems. | type=String | max_len=25']
