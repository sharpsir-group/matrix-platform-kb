  cc_email_list varchar(1024) [note: 'CcEmailList | A comma-separated list of email addresses that are the carbon copy (Cc) address that the automated emails are being sent to. | type=String | max_len=1024']
  client_activated_yn bool [note: 'ClientActivatedYN | If set to True, the client has clicked through to accept automatic emails. | type=Boolean']
  concierge_notifications_yn bool [note: 'ConciergeNotificationsYN | If set to True, notifications are to be sent to the member when the auto email is in Concierge mode. | type=Boolean']
  concierge_yn bool [note: 'ConciergeYN | When set to True, the automated mail is in Concierge mode and is to be approved by the member before being sent to the client. | type=Boolean']
  contact_key varchar(255) [note: 'ContactKey | This is the foreign key relating to the Contacts Resource. | type=String | max_len=255']
  daily_schedule varchar [note: 'DailySchedule | When Daily is selected as the ScheduleType, a list of days of the week and AM or PM options. | type=String List, Multi | max_len=1024 | multi: DailySchedule | lookup=DailySchedule']
  display_template_id varchar(25) [note: 'DisplayTemplateID | The system ID of the display that has been related or set as the default to this saved search. | type=String | max_len=25']
  language languages [note: 'Language | The language that will be used in the given automated email. | type=String List, Single | max_len=25 | lookup=Languages']
  last_new_changed_timestamp timestamp [note: 'LastNewChangedTimestamp | The timestamp of when the prospector last found new or modified listings for an automated email. | type=Timestamp | max_len=27']
  last_viewed_timestamp timestamp [note: 'LastViewedTimestamp | A timestamp of when the automated email was last viewed by the client in the portal. | type=Timestamp | max_len=27']
  message_new varchar [note: 'MessageNew | The body of the automated email message when the first email is sent for the prospecting campaign. | type=String | max_len=4000']
  message_revise varchar [note: 'MessageRevise | The body of the automated email message to be used when the criteria or settings of an automated email has been modified. | type=String | max_len=4000']
  message_update varchar [note: 'MessageUpdate | The body of the automated email message for subsequent email messages after the first email is sent. | type=String | max_len=4000']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time the Prospecting record was last modified. | type=Timestamp | max_len=27']
  next_send_timestamp timestamp [note: 'NextSendTimestamp | A timestamp of when the automated email is schedule to next send. | type=Timestamp | max_len=27']
  owner_member_id varchar(25) [note: 'OwnerMemberID | The local, well-known identifier for the member owning the contact. | type=String | max_len=25']
  owner_member_key varchar(255) [note: 'OwnerMemberKey | The unique identifier (key) of the member owning the contact. | type=String | max_len=255']
  prospecting_key varchar(255) [pk, note: 'ProspectingKey | A unique identifier for this record from the immediate source. | type=String | max_len=255']
  reason_active_or_disabled reason_active_or_disabled [note: 'ReasonActiveOrDisabled | A list of reasons the automated email was set to inactive or set back to active (e.g., Agent Disabled, Over Limit, No Listings Found, Reactivated, Client Disabled). | type=String List, Single | max_len=50 | lookup=ReasonActiveOrDisabled']
  saved_search_key varchar(255) [note: 'SavedSearchKey | This is the foreign key relating to the SavedSearch Resource. | type=String | max_len=255']
  schedule_type schedule_type [note: 'ScheduleType | A selection of the type of schedule that the automated email will be sent (i.e., Daily, Monthly or ASAP). | type=String List, Single | max_len=25 | lookup=ScheduleType']
  subject varchar(255) [note: 'Subject | The subject line of the automated email being sent. | type=String | max_len=255']
  to_email_list varchar(1024) [note: 'ToEmailList | A comma-separated list of email addresses that are the "To" address the automated emails are being sent to. | type=String | max_len=1024']
}

