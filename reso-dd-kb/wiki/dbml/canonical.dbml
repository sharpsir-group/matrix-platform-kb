// canonical.dbml
// RESO Data Dictionary 2.0 canonical schema (2NF normalised)
// Generated by reso-dd-kb/scripts/05_emit_dbml.py from Phase 1/2/2.5 CSVs.
// Companion file: lookups.dbml (Enum blocks for SV lookups).

Project reso_canonical_dd_2_0 {
  database_type: 'PostgreSQL'
  Note: '''
    RESO Data Dictionary 2.0, derived from a verifiable mirror of dd.reso.org/DD2.0/.
    Tables: 41 (one per Resource).  FKs: from raw/relationships.csv (high + medium confidence).
    Column drops: from raw/satellites.csv recommendation == drop_from_host (Phase 2.5).
    Review markers: rows with recommendation == review carry a // REVIEW comment.
  '''
}

