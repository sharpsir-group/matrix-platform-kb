  listing_viewed_yn bool [note: 'ListingViewedYN | Indicates whether or not a listing has been viewed. | type=Boolean']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time the ContactListing record was last modified. | type=Timestamp | max_len=27']
  portal_last_visited_timestamp timestamp [note: 'PortalLastVisitedTimestamp | The date/time the listing was last viewed by the contact. | type=Timestamp | max_len=27']
  resource_name resource_name [note: 'ResourceName | The name of the resource where the listing record is located. | type=String List, Single | max_len=50 | lookup=ResourceName']
}

// ---- Contacts (91 fields on dd.reso.org) ----
// inverse 1:N: ContactsOtherPhone -> OtherPhone
// inverse 1:N: ContactsSocialMedia -> SocialMedia
// inverse 1:N: HistoryTransactional -> HistoryTransactional
// inverse 1:N: Media -> Media
Table contacts {
  anniversary date [note: 'Anniversary | The month, day and year of the contact\'s wedding anniversary. | type=Date | max_len=24']
  assistant_email varchar(80) [note: 'AssistantEmail | The email address of the contact\'s assistant. | type=String | max_len=80']
  assistant_name varchar(150) [note: 'AssistantName | The name of the contact\'s assistant. | type=String | max_len=150']
