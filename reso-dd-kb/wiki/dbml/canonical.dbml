  home_carrier_route varchar(9) [note: 'HomeCarrierRoute | The group of addresses to which the U.S. | type=String | max_len=9']
  home_city varchar(50) [note: 'HomeCity | The city of the contact\'s home. | type=String | max_len=50']
  home_country country [note: 'HomeCountry | The country abbreviation in a postal address. | type=String List, Single | max_len=2 | lookup=Country']
  home_county_or_parish varchar [note: 'HomeCountyOrParish | The county or parish in which the contact\'s home is addressed. | type=String List, Single | max_len=50 | open: jurisdiction-defined; no closed value list | lookup=CountyOrParish']
  home_fax varchar(16) [note: 'HomeFax | North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  home_phone varchar(16) [note: 'HomePhone | North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  home_postal_code varchar(10) [note: 'HomePostalCode | The postal code of the contact\'s home. | type=String | max_len=10']
  home_postal_code_plus4 varchar(4) [note: 'HomePostalCodePlus4 | The four-digit extension of the U.S. | type=String | max_len=4']
  home_state_or_province state_or_province [note: 'HomeStateOrProvince | The state or province in which the contact\'s home is addressed. | type=String List, Single | max_len=2 | lookup=StateOrProvince']
  job_title varchar(50) [note: 'JobTitle | The title or position of the contact within their organization. | type=String | max_len=50']
