  open_house_key varchar(255) [pk, note: 'OpenHouseKey | A unique identifier for this record from the immediate source. | type=String | max_len=255']
  open_house_remarks varchar(500) [note: 'OpenHouseRemarks | Comments, instructions or information about the open house. | type=String | max_len=500']
  open_house_start_time timestamp [note: 'OpenHouseStartTime | The time the open house begins. | type=Timestamp | max_len=27']
  open_house_status open_house_status [note: 'OpenHouseStatus | Status of the open house (i.e., Active, Canceled, Ended). | type=String List, Single | max_len=25 | lookup=OpenHouseStatus']
  open_house_type open_house_type [note: 'OpenHouseType | The type of open house (i.e., Public, Broker, Office, Association, Private (invitation or targeted publication)). | type=String List, Single | max_len=25 | lookup=OpenHouseType']
  original_entry_timestamp timestamp [note: 'OriginalEntryTimestamp | The transactional timestamp automatically recorded by the MLS system representing the date/time the open house was entered and made visible to members of the MLS. | type=Timestamp | max_len=27']
  originating_system_id varchar(25) [note: 'OriginatingSystemID | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the originating record provider. | type=String | max_len=25']
  originating_system_key varchar(255) [note: 'OriginatingSystemKey | The system key, a unique record identifier, from the originating system. | type=String | max_len=255']
  originating_system_name varchar(255) [note: 'OriginatingSystemName | The name of the originating record provider, most commonly the name of the MLS. | type=String | max_len=255']
  refreshments varchar(255) [note: 'Refreshments | A description of the refreshments that will be served at the open house. | type=String | max_len=255']
  showing_agent_key varchar(255) [note: 'ShowingAgentKey | A system unique identifier. | type=String | max_len=255']
  source_system_id varchar(25) [note: 'SourceSystemID | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the source record provider. | type=String | max_len=25']
  source_system_key varchar(255) [note: 'SourceSystemKey | The system key, a unique record identifier, from the source system. | type=String | max_len=255']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the open house record provider. | type=String | max_len=255']
}

// ---- OtherPhone (10 fields on dd.reso.org) ----
// inverse 1:N: HistoryTransactional -> HistoryTransactional
Table other_phone {
  class_name class_name [note: 'ClassName | Name of the class to which the record is referencing. | type=String List, Single | max_len=255 | lookup=ClassName']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The transactional timestamp automatically recorded by the MLS system representing the date/time the OtherPhone record was last modified. | type=Timestamp | max_len=27']
  other_phone_ext varchar(10) [note: 'OtherPhoneExt | The extension of the given phone number (if applicable). | type=String | max_len=10']
  other_phone_key varchar(255) [pk, note: 'OtherPhoneKey | A system unique identifier. | type=String | max_len=255']
  other_phone_number varchar(16) [note: 'OtherPhoneNumber | The phone option allowing members to convey additional phone numbers other than those already covered by the MemberMobilePhone, MemberFax and other specified fields. | type=String | max_len=16']
  other_phone_type other_phone_type [note: 'OtherPhoneType | The type of phone record that does not already exist in the given phone fields or if a second of any type of phone field is needed (i.e., HomePhone2, BrothersPhone, etc.). | type=String List, Single | max_len=25 | lookup=OtherPhoneType']
  resource_name resource_name [note: 'ResourceName | The resource or table of the listing or other record the media relates to (i.e., Property, Member, Office, etc.). | type=String List, Single | max_len=50 | lookup=ResourceName']
  resource_record_id varchar(255) [note: 'ResourceRecordID | The well-known identifier of the related record from the source resource. | type=String | max_len=255']
  resource_record_key varchar(255) [note: 'ResourceRecordKey | The primary key of the related record from the source resource (e.g., ListingKey, AgentKey, OfficeKey, TeamKey). | type=String | max_len=255']
}

