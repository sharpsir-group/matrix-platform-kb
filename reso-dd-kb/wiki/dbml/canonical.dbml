  stop_order int [note: 'StopOrder | This is used when the order of stops needs to be communicated. | type=Number | max_len=2']
  stop_refreshments varchar(255) [note: 'StopRefreshments | A description of the refreshments that will be served at the caravan stop. | type=String | max_len=255']
  stop_remarks varchar(500) [note: 'StopRemarks | Comments, instructions or information about the caravan stop. | type=String | max_len=500']
  stop_resource_name caravan_resource_name [note: 'StopResourceName | The name of the resource that applies to this caravan stop record. | type=String List, Single | max_len=50 | lookup=CaravanResourceName']
