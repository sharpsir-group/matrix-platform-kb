  rule_action varchar [note: 'RuleAction | The action to be taken when processing the rule. | type=String | max_len=8000']
  rule_description varchar [note: 'RuleDescription | A detailed textual description of the rule. | type=String | max_len=8000']
  rule_enabled_yn bool [note: 'RuleEnabledYN | Is the rule currently enabled? | type=Boolean']
  rule_error_text varchar [note: 'RuleErrorText | Textual information conveyed when the given rule is in error or fails (e.g., the listing price must be greater than 0). | type=String | max_len=8000']
  rule_expression varchar [note: 'RuleExpression | The expression or details of the rule. | type=String | max_len=8000']
  rule_format rule_format [note: 'RuleFormat | The format of the rule (e.g., $filter, JavaScript, REBR). | type=String List, Single | max_len=50 | lookup=RuleFormat']
  rule_help_text varchar [note: 'RuleHelpText | The text that might be displayed on a form that helps the user fix the rule (e.g., enter phone number in the following 10-digit format: ###-###-####). | type=String | max_len=8000']
  rule_key varchar(255) [pk, note: 'RuleKey | The primary key of the individual Rule record. | type=String | max_len=255']
  rule_name varchar(255) [note: 'RuleName | A descriptive name for the rule. | type=String | max_len=255']
  rule_order int [note: 'RuleOrder | When in use, execution of rules are to follow the order specified by this field. | type=Number | max_len=64']
  rule_type varchar [note: 'RuleType | The type of rule (e.g., Validation, Required, Warning, etc.). | type=String List, Single | max_len=50 | open: jurisdiction-defined; no closed value list | lookup=RuleType']
  rule_version varchar(255) [note: 'RuleVersion | A rule version that uses semantic versioning. | type=String | max_len=255']
  rule_warning_text varchar [note: 'RuleWarningText | Textual information conveyed when a given rule has met a condition that warrants a warning message (e.g., sale price entered differs from listing price by more than 25%). | type=String | max_len=8000']
  source_system_history_key varchar(255) [note: 'SourceSystemHistoryKey | The system key, a unique record identifier, from the source system. | type=String | max_len=255']
  source_system_id varchar(25) [note: 'SourceSystemID | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the source record provider. | type=String | max_len=25']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the rule record provider, that being the system from which the record was directly received and the legal name of the company. | type=String | max_len=255']
}

