// ---- PropertyGreenVerification (15 fields on dd.reso.org) ----
// inverse 1:N: HistoryTransactional -> HistoryTransactional
Table property_green_verification {
  green_building_verification_key varchar(255) [pk, note: 'GreenBuildingVerificationKey | A unique identifier for this record. | type=String | max_len=255']
  green_building_verification_type green_building_verification_type [note: 'GreenBuildingVerificationType | The name of the verification or certification awarded to a new or pre-existing residential or commercial structure (e.g., LEED, ENERGY STAR, ICC-700). | type=String List, Single | max_len=1024 | lookup=GreenBuildingVerificationType']
  green_verification_body varchar(50) [note: 'GreenVerificationBody | The name of the body or group providing the verification/certification/rating named in the GreenBuildingVerificationType field. | type=String | max_len=50']
  green_verification_metric int [note: 'GreenVerificationMetric | A final score indicating the performance of energy efficiency design and measures in the home as tested by a third-party rater. | type=Number | max_len=3']
  green_verification_rating varchar(50) [note: 'GreenVerificationRating | Many verifications or certifications have a rating system that provides an indication of the structure\'s level of energy efficiency. | type=String | max_len=50']
  green_verification_source green_verification_source [note: 'GreenVerificationSource | The source of the green data. | type=String List, Single | max_len=25 | lookup=GreenVerificationSource']
  green_verification_status green_verification_status [note: 'GreenVerificationStatus | Many verification programs include a multistep process that may begin with plans and specs, involve testing and/or submission of building specifications along the way, and include a final verification step. | type=String List, Single | max_len=25 | lookup=GreenVerificationStatus']
  green_verification_url varchar [note: 'GreenVerificationURL | Provides a link to the specific property\'s high-performance rating or scoring details directly from and hosted by the sponsoring body of the program. | type=String | max_len=8000']
  green_verification_version varchar(25) [note: 'GreenVerificationVersion | The version of the green certification or verification that was awarded. | type=String | max_len=25']
  green_verification_year int [note: 'GreenVerificationYear | The year the green certification or verification was awarded. | type=Number | max_len=4']
  listing_id varchar(255) [note: 'ListingId | This is the foreign ID relating to the property. | type=String | max_len=255']
  listing_key varchar(255) [note: 'ListingKey | This is the foreign key relating to the property. | type=String | max_len=255']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time the PropertyGreenVerification record was last modified. | type=Timestamp | max_len=27']
}

