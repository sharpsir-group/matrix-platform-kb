  showing_requested_timestamp timestamp [note: 'ShowingRequestedTimestamp | The date/time when the showing agent submitted a request to access the property. | type=Timestamp | max_len=27']
  showing_requestor varchar [note: 'ShowingRequestor | The role of the person making the request (e.g., showing agent, inspector, buyer, tenant). | type=String List, Multi | max_len=1024 | multi: ShowingRequestor | lookup=ShowingRequestor']
}

