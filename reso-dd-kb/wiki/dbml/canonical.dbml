  resource_record_key varchar(255) [note: 'ResourceRecordKey | The primary key of the related record from the source resource (e.g., ListingKey, AgentKey, OfficeKey). | type=String | max_len=255']
  source_system_id varchar(25) [note: 'SourceSystemID | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the source record provider. | type=String | max_len=25']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the queue record provider. | type=String | max_len=255']
  source_system_queue_key varchar(255) [note: 'SourceSystemQueueKey | The system key, a unique record identifier, from the source system, which is the system from which the record was directly received. | type=String | max_len=255']
}

// ---- Rules (28 fields on dd.reso.org) ----
