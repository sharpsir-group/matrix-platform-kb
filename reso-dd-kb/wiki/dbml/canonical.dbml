Table association {
  association_address1 varchar(50) [note: 'AssociationAddress1 | The street number, direction, name and suffix of the association. | type=String | max_len=50']
  association_address2 varchar(50) [note: 'AssociationAddress2 | The unit/suite number of the association. | type=String | max_len=50']
  association_care_of varchar(30) [note: 'AssociationCareOf | The care of (c/o) information for the association\'s street address. | type=String | max_len=30']
