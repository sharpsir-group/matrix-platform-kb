  association_city varchar(50) [note: 'AssociationCity | The city where the association is located. | type=String | max_len=50']
  association_country country [note: 'AssociationCountry | The association\'s country code for the street address. | type=String List, Single | max_len=2 | lookup=Country']
  association_county_or_parish varchar [note: 'AssociationCountyOrParish | The association\'s county of the street address. | type=String List, Single | max_len=50 | open: jurisdiction-defined; no closed value list | lookup=CountyOrParish']
  association_fax varchar(16) [note: 'AssociationFax | The North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  association_key varchar(255) [pk, note: 'AssociationKey | The unique identifier for the association record. | type=String | max_len=255']
  association_mail_address1 varchar(50) [note: 'AssociationMailAddress1 | The street number, direction, name and suffix of the association\'s mailing address. | type=String | max_len=50']
