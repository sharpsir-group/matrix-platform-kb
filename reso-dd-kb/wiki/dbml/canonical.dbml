  association_mail_county_or_parish varchar [note: 'AssociationMailCountyOrParish | The county in which the association\'s mailing address is located. | type=String List, Single | max_len=50 | open: jurisdiction-defined; no closed value list | lookup=CountyOrParish']
  association_mail_postal_code varchar(10) [note: 'AssociationMailPostalCode | The postal code in which the association\'s mail is received. | type=String | max_len=10']
  association_mail_postal_code_plus4 varchar(4) [note: 'AssociationMailPostalCodePlus4 | The four-digit extension of the U.S. | type=String | max_len=4']
  association_mail_state_of_province state_or_province [note: 'AssociationMailStateOfProvince | The state or province in which the association\'s mail is received. | type=String List, Single | max_len=2 | lookup=StateOrProvince']
  association_mls_id varchar(25) [note: 'AssociationMlsId | The local, well-known identifier for the association of REALTORS®. | type=String | max_len=25']
  association_name varchar(255) [note: 'AssociationName | The name of the association. | type=String | max_len=255']
  association_national_association_id varchar(25) [note: 'AssociationNationalAssociationId | The national association ID of the association as known by the National Association of REALTORS®. | type=String | max_len=25']
  association_phone varchar(16) [note: 'AssociationPhone | The North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). | type=String | max_len=16']
  association_postal_code varchar(10) [note: 'AssociationPostalCode | The postal code of the association. | type=String | max_len=10']
  association_postal_code_plus4 varchar(4) [note: 'AssociationPostalCodePlus4 | The four-digit extension of the U.S. | type=String | max_len=4']
  association_state_or_province state_or_province [note: 'AssociationStateOrProvince | The state or province in which the association is addressed. | type=String List, Single | max_len=2 | lookup=StateOrProvince']
  association_status association_status [note: 'AssociationStatus | The status of the association (i.e., Active, Inactive). | type=String List, Single | max_len=25 | lookup=AssociationStatus']
  association_type association_type [note: 'AssociationType | The type of association (MLS, Local, Not Applicable, etc.). | type=String List, Single | max_len=50 | lookup=AssociationType']
  executive_officer_member_key varchar(255) [note: 'ExecutiveOfficerMemberKey | The executive officer\'s member key. | type=String | max_len=255']
  executive_officer_member_mls_id varchar(25) [note: 'ExecutiveOfficerMemberMlsId | The local, well-known identifier for the executive officer. | type=String | max_len=25']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time the Association record was last modified. | type=Timestamp | max_len=27']
  multiple_listing_service_id varchar(25) [note: 'MultipleListingServiceId | The ID of the Multiple Listing Service (MLS) used by the association. | type=String | max_len=25']
  original_entry_timestamp timestamp [note: 'OriginalEntryTimestamp | Date/time the record was originally input into the source system. | type=Timestamp | max_len=27']
  originating_system_association_key varchar(255) [note: 'OriginatingSystemAssociationKey | The system key, a unique record identifier, from the originating system. | type=String | max_len=255']
  originating_system_id varchar(25) [note: 'OriginatingSystemId | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the originating record provider. | type=String | max_len=25']
  originating_system_name varchar(255) [note: 'OriginatingSystemName | The name of the originating record provider, most commonly the name of the MLS. | type=String | max_len=255']
  social_media_type social_media_type [note: 'SocialMediaType | A list of types of websites or social media the association Uniform Resource Locator (URL) or ID is referring to (e.g., Website, Blog, Facebook, Twitter, LinkedIn, Instagram). | type=String List, Single | max_len=25 | lookup=SocialMediaType']
  social_media_url_or_id varchar [note: 'SocialMediaUrlOrId | The website URL or ID of social media site or account of the Association. | type=String | max_len=8000']
  source_system_association_key varchar(255) [note: 'SourceSystemAssociationKey | The system key, a unique record identifier, from the source system. | type=String | max_len=255']
  source_system_id varchar(25) [note: 'SourceSystemId | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the source record provider. | type=String | max_len=25']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the immediate record provider. | type=String | max_len=255']
}

// ---- Caravan (33 fields on dd.reso.org) ----
Table caravan {
  cancellation_policy_url varchar [note: 'CancellationPolicyUrl | The Uniform Resource Locator (aka, URL or link) to the cancellation policy of the tour organizer. | type=String | max_len=8000']
  caravan_allowed_class_names varchar [note: 'CaravanAllowedClassNames | A comma-separated list of the classes allowed by the tour\'s host. | type=String List, Multi | max_len=50 | multi: CaravanAllowedClassNames | lookup=CaravanAllowedClassNames']
  caravan_allowed_statuses varchar [note: 'CaravanAllowedStatuses | A comma-separated list of the listing statuses allowed by the tour\'s host. | type=String List, Multi | max_len=50 | multi: CaravanAllowedStatuses | lookup=CaravanAllowedStatuses']
  caravan_area_description varchar(1024) [note: 'CaravanAreaDescription | A textual description of the geographic or locally known areas that all properties to be included in the tour must be located. | type=String | max_len=1024']
  caravan_blackout_dates varchar(1024) [note: 'CaravanBlackoutDates | A comma-separated list of the dates when a reoccurring tour will not take place (e.g., holidays, weekends, etc.). | type=String | max_len=1024']
  caravan_date date [note: 'CaravanDate | The date of the organized tour. | type=Date | max_len=10']
  caravan_days_recurring varchar(50) [note: 'CaravanDaysRecurring | Used with unbound timeframes (e.g., second Tuesday of month). | type=String | max_len=50']
  caravan_end_time timestamp [note: 'CaravanEndTime | The end time of the organized tour. | type=Timestamp | max_len=27']
  caravan_input_deadline_description varchar(50) [note: 'CaravanInputDeadlineDescription | A textual description of the deadline to add a stop (property or open house) to the tour. | type=String | max_len=50']
  caravan_input_deadline_timestamp timestamp [note: 'CaravanInputDeadlineTimestamp | A date/time of the deadline to add a stop (property or open house) to the tour. | type=Timestamp | max_len=27']
  caravan_key varchar(255) [pk, note: 'CaravanKey | A system unique identifier. | type=String | max_len=255']
  caravan_name varchar(50) [note: 'CaravanName | The name or short description of the tour. | type=String | max_len=50']
  caravan_organizer_contact_info varchar(255) [note: 'CaravanOrganizerContactInfo | Contact information for the tour organizer, such as phone or email. | type=String | max_len=255']
  caravan_organizer_key varchar(255) [note: 'CaravanOrganizerKey | A system unique identifier for the entity hosting the tour. | type=String | max_len=255']
  caravan_organizer_mls_id varchar(25) [note: 'CaravanOrganizerMlsId | The local, well-known identifier for the entity hosting the tour. | type=String | max_len=25']
  caravan_organizer_name varchar(255) [note: 'CaravanOrganizerName | The name of the entity hosting the tour. | type=String | max_len=255']
  caravan_organizer_resource_name caravan_resource_name [note: 'CaravanOrganizerResourceName | The resource or table of the record to which the CaravanOrganizerKey or MlsId refers (i.e., Office, Association, etc.). | type=String List, Single | max_len=255 | lookup=CaravanResourceName']
  caravan_policy_url varchar [note: 'CaravanPolicyUrl | The Uniform Resource Locator (aka, URL or link) to the general tour policies of the tour organizer. | type=String | max_len=8000']
  caravan_remarks varchar(500) [note: 'CaravanRemarks | The detailed description, directions, policy or other details about the tour. | type=String | max_len=500']
  caravan_start_location varchar(50) [note: 'CaravanStartLocation | A description or address of the location where the tour begins. | type=String | max_len=50']
  caravan_start_location_giveaways varchar(255) [note: 'CaravanStartLocationGiveaways | A description of prizes, drawings, etc., that will be given at the tour start location. | type=String | max_len=255']
  caravan_start_location_refreshments varchar(255) [note: 'CaravanStartLocationRefreshments | A description of the refreshments that will be served at the tour start location. | type=String | max_len=255']
  caravan_start_time timestamp [note: 'CaravanStartTime | The start time of the organized tour. | type=Timestamp | max_len=27']
  caravan_status caravan_status [note: 'CaravanStatus | Status of the organized tour (e.g., Active, Cancelled, Ended, etc.). | type=String List, Single | max_len=25 | lookup=CaravanStatus']
  caravan_type caravan_type [note: 'CaravanType | The type of organized tour (e.g., AOR, Broker, Other, etc.). | type=String List, Single | max_len=25 | lookup=CaravanType']
  modification_timestamp timestamp [note: 'ModificationTimestamp | The date/time the Caravan record was last modified. | type=Timestamp | max_len=27']
  original_entry_timestamp timestamp [note: 'OriginalEntryTimestamp | The date/time the Caravan record was originally input into the source system. | type=Timestamp | max_len=27']
  originating_system_id varchar(25) [note: 'OriginatingSystemId | The RESO UOI\'s OrganizationUniqueId of the originating record provider. | type=String | max_len=25']
  originating_system_key varchar(255) [note: 'OriginatingSystemKey | The system key, a unique record identifier, from the originating system. | type=String | max_len=255']
  originating_system_name varchar(255) [note: 'OriginatingSystemName | The name of the originating record provider. | type=String | max_len=255']
  source_system_id varchar(25) [note: 'SourceSystemId | The RESO UOI\'s OrganizationUniqueId of the source record provider. | type=String | max_len=25']
  source_system_key varchar(255) [note: 'SourceSystemKey | The system key, a unique record identifier, from the source system. | type=String | max_len=255']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the CaravanStop record provider. | type=String | max_len=255']
}

