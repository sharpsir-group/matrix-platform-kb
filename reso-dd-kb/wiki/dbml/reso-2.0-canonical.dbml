// ---- Association (RESO 2.0 canonical) ----
Table association {
  association_key varchar(255) [pk, note: 'AssociationKey | The unique identifier for the association record. | type=String | max_len=255.0 | adoption org=0% (1/344)']
  association_address1 varchar(50) [note: 'AssociationAddress1 | The street number, direction, name and suffix of the association. | type=String | max_len=50.0']
  association_address2 varchar(50) [note: 'AssociationAddress2 | The unit/suite number of the association. | type=String | max_len=50.0']
  association_care_of varchar(30) [note: 'AssociationCareOf | The care of (c/o) information for the association\'s street address. | type=String | max_len=30.0']
  association_charter_date date [note: 'AssociationCharterDate | The charter date for the association. | type=Date | max_len=10.0']
  association_city varchar(50) [note: 'AssociationCity | The city where the association is located. | type=String | max_len=50.0']
  association_country varchar [note: 'AssociationCountry | The association\'s country code for the street address. | type=String List, Single | lookup=Country | max_len=2.0']
  association_county_or_parish varchar [note: 'AssociationCountyOrParish | The association\'s county of the street address. | type=String List, Single | lookup=CountyOrParish | max_len=50.0']
  association_fax varchar(16) [note: 'AssociationFax | The North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). Other conventions should use the common local standard | type=String | max_len=16.0']
  association_mail_address1 varchar(50) [note: 'AssociationMailAddress1 | The street number, direction, name and suffix of the association\'s mailing address. | type=String | max_len=50.0']
  association_mail_address2 varchar(50) [note: 'AssociationMailAddress2 | The unit/suite number of the association\'s mailing address. | type=String | max_len=50.0']
  association_mail_care_of varchar(30) [note: 'AssociationMailCareOf | The care of (c/o) information for the association\'s mailing address. | type=String | max_len=30.0']
  association_mail_city varchar(50) [note: 'AssociationMailCity | The city in which the association\'s mail is received. | type=String | max_len=50.0']
  association_mail_country varchar [note: 'AssociationMailCountry | The country code for the association\'s mailing address. | type=String List, Single | lookup=Country | max_len=2.0']
  association_mail_county_or_parish varchar [note: 'AssociationMailCountyOrParish | The county in which the association\'s mailing address is located. | type=String List, Single | lookup=CountyOrParish | max_len=50.0']
  association_mail_postal_code varchar(10) [note: 'AssociationMailPostalCode | The postal code in which the association\'s mail is received. | type=String | max_len=10.0']
  association_mail_postal_code_plus4 varchar(4) [note: 'AssociationMailPostalCodePlus4 | The four-digit extension of the U.S. Zip Code for the association\'s mailing address. | type=String | max_len=4.0']
  association_mail_state_of_province varchar [note: 'AssociationMailStateOfProvince | The state or province in which the association\'s mail is received. | type=String List, Single | lookup=StateOrProvince | max_len=2.0']
