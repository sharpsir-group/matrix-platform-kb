  association_name varchar(255) [note: 'AssociationName | The name of the association. | type=String | max_len=255.0 | adoption org=0% (1/344)']
  association_national_association_id varchar(25) [note: 'AssociationNationalAssociationId | The national association ID of the association as known by the National Association of REALTORS®. | type=String | max_len=25.0']
  association_phone varchar(16) [note: 'AssociationPhone | The North American 10-digit phone numbers should be in the format of ###-###-#### (separated by hyphens). Other conventions should use the common local standard | type=String | max_len=16.0']
  association_postal_code varchar(10) [note: 'AssociationPostalCode | The postal code of the association. | type=String | max_len=10.0']
  association_postal_code_plus4 varchar(4) [note: 'AssociationPostalCodePlus4 | The four-digit extension of the U.S. Zip Code. | type=String | max_len=4.0']
  association_social_media text [note: 'AssociationSocialMedia | A collection of the types of social media fields available for the association, including the type of system and other details pertinent to social media. | type=Collection']
  association_state_or_province varchar [note: 'AssociationStateOrProvince | The state or province in which the association is addressed. | type=String List, Single | lookup=StateOrProvince | max_len=2.0']
  association_status varchar [note: 'AssociationStatus | The status of the association (i.e., Active, Inactive). | type=String List, Single | lookup=AssociationStatus | max_len=25.0']
  association_type varchar [note: 'AssociationType | The type of association (MLS, Local, Not Applicable, etc.). | type=String List, Single | lookup=AssociationType | max_len=50.0']
  executive_officer_member_key varchar(255) [note: 'ExecutiveOfficerMemberKey | The executive officer\'s member key. | type=String | max_len=255.0']
