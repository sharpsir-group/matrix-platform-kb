  source_system_id varchar(25) [note: 'SourceSystemId | The RESO Unique Organization Identifier (UOI) OrganizationUniqueId of the source record provider. The source system is the system from which the record was dire | type=String | max_len=25.0']
  source_system_name varchar(255) [note: 'SourceSystemName | The name of the immediate record provider. The system from which the record was directly received. The legal name of the company. | type=String | max_len=255.0']
