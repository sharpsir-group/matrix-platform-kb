// ---- Caravan (RESO 2.0 canonical) ----
Table caravan {
  caravan_key varchar(255) [pk, note: 'CaravanKey | A system unique identifier. Specifically, in aggregation systems, the CaravanKey is the system unique identifier from the system that the record was retrieved. | type=String | max_len=255.0']
  cancellation_policy_url varchar(8000) [note: 'CancellationPolicyUrl | The Uniform Resource Locator (aka, URL or link) to the cancellation policy of the tour organizer. | type=String | max_len=8000.0']
  caravan_allowed_class_names varchar [note: 'CaravanAllowedClassNames | A comma-separated list of the classes allowed by the tour\'s host. | type=String List, Multi | lookup=CaravanAllowedClassNames (multi) | max_len=50.0']
  caravan_allowed_statuses varchar [note: 'CaravanAllowedStatuses | A comma-separated list of the listing statuses allowed by the tour\'s host. | type=String List, Multi | lookup=CaravanAllowedStatuses (multi) | max_len=50.0']
  caravan_area_description varchar(1024) [note: 'CaravanAreaDescription | A textual description of the geographic or locally known areas that all properties to be included in the tour must be located. | type=String | max_len=1024.0']
  caravan_blackout_dates varchar(1024) [note: 'CaravanBlackoutDates | A comma-separated list of the dates when a reoccurring tour will not take place (e.g., holidays, weekends, etc.). | type=String | max_len=1024.0']
  caravan_date date [note: 'CaravanDate | The date of the organized tour. | type=Date | max_len=10.0']
  caravan_days_recurring varchar(50) [note: 'CaravanDaysRecurring | Used with unbound timeframes (e.g., second Tuesday of month). | type=String | max_len=50.0']
  caravan_end_time timestamp [note: 'CaravanEndTime | The end time of the organized tour. | type=Timestamp | max_len=27.0']
  caravan_input_deadline_description varchar(50) [note: 'CaravanInputDeadlineDescription | A textual description of the deadline to add a stop (property or open house) to the tour. | type=String | max_len=50.0']
  caravan_input_deadline_timestamp timestamp [note: 'CaravanInputDeadlineTimestamp | A date/time of the deadline to add a stop (property or open house) to the tour. | type=Timestamp | max_len=27.0']
  caravan_name varchar(50) [note: 'CaravanName | The name or short description of the tour. | type=String | max_len=50.0']
  caravan_organizer_contact_info varchar(255) [note: 'CaravanOrganizerContactInfo | Contact information for the tour organizer, such as phone or email. | type=String | max_len=255.0']
  caravan_organizer_key varchar(255) [note: 'CaravanOrganizerKey | A system unique identifier for the entity hosting the tour. Specifically, in aggregation systems, the Key is the system unique identifier from the system that t | type=String | max_len=255.0']
  caravan_organizer_mls_id varchar(25) [note: 'CaravanOrganizerMlsId | The local, well-known identifier for the entity hosting the tour. This value may not be unique, specifically in the case of aggregation systems, this value shou | type=String | max_len=25.0']
  caravan_organizer_name varchar(255) [note: 'CaravanOrganizerName | The name of the entity hosting the tour. | type=String | max_len=255.0']
  caravan_organizer_resource_name varchar [note: 'CaravanOrganizerResourceName | The resource or table of the record to which the CaravanOrganizerKey or MlsId refers (i.e., Office, Association, etc.). | type=String List, Single | lookup=CaravanResourceName | max_len=255.0']
  caravan_policy_url varchar(8000) [note: 'CaravanPolicyUrl | The Uniform Resource Locator (aka, URL or link) to the general tour policies of the tour organizer. | type=String | max_len=8000.0']
  caravan_remarks varchar(500) [note: 'CaravanRemarks | The detailed description, directions, policy or other details about the tour. | type=String | max_len=500.0']
  caravan_start_location varchar(50) [note: 'CaravanStartLocation | A description or address of the location where the tour begins. This is typically not one of the stops but an event where each of the stops are presented, gener | type=String | max_len=50.0']
  caravan_start_location_giveaways varchar(255) [note: 'CaravanStartLocationGiveaways | A description of prizes, drawings, etc., that will be given at the tour start location. | type=String | max_len=255.0']
  caravan_start_location_refreshments varchar(255) [note: 'CaravanStartLocationRefreshments | A description of the refreshments that will be served at the tour start location. | type=String | max_len=255.0']
  caravan_start_time timestamp [note: 'CaravanStartTime | The start time of the organized tour. | type=Timestamp | max_len=27.0']
