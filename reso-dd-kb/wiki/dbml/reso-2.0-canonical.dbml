  originating_system_name varchar(255) [note: 'OriginatingSystemName | The name of the originating record provider, most commonly the name of the MLS. The place where the office is originally input by the association. | type=String | max_len=255.0 | adoption org=0% (1/344)']
  social_media_type varchar [note: 'SocialMediaType | A list of types of websites or social media the association Uniform Resource Locator (URL) or ID is referring to (e.g., Website, Blog, Facebook, Twitter, Linked | type=String List, Single | lookup=SocialMediaType | max_len=25.0']
